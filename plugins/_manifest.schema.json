{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MaiBot Plugin Manifest",
  "description": "MaiBot 插件清单文件格式，用于声明插件的元数据、依赖和能力",
  "type": "object",
  "required": [
    "manifest_version",
    "version",
    "name",
    "description",
    "author",
    "license",
    "urls",
    "host_application",
    "sdk",
    "capabilities",
    "i18n",
    "id"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 引用路径，仅用于编辑器自动补全和语法检查；运行时解析前会忽略该字段",
      "minLength": 1,
      "pattern": "\\S"
    },
    "manifest_version": {
      "type": "integer",
      "description": "清单格式版本号，当前必须为 2",
      "enum": [
        2
      ],
      "default": 2
    },
    "version": {
      "type": "string",
      "description": "插件版本号，必须为严格三段式语义版本号",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": [
        "1.0.0",
        "2.1.3"
      ]
    },
    "name": {
      "type": "string",
      "description": "插件显示名称，用于在 UI 中展示",
      "minLength": 1,
      "pattern": "\\S"
    },
    "description": {
      "type": "string",
      "description": "插件功能描述，简要说明插件的用途和特性",
      "minLength": 1,
      "pattern": "\\S"
    },
    "author": {
      "type": "object",
      "description": "插件作者信息",
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "作者名称或组织名称",
          "minLength": 1,
          "pattern": "\\S"
        },
        "url": {
          "type": "string",
          "description": "作者主页、GitHub 个人页面或组织页面，必须为 http(s) URL",
          "pattern": "^https?://.*\\S$"
        }
      },
      "additionalProperties": false
    },
    "license": {
      "type": "string",
      "description": "插件协议",
      "minLength": 1,
      "pattern": "\\S"
    },
    "urls": {
      "type": "object",
      "description": "插件相关链接",
      "required": [
        "repository"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "description": "代码仓库地址，必须为 http(s) URL",
          "pattern": "^https?://.*\\S$"
        },
        "homepage": {
          "type": "string",
          "description": "项目主页或文档站点，必须为 http(s) URL",
          "pattern": "^https?://.*\\S$"
        },
        "documentation": {
          "type": "string",
          "description": "插件使用文档地址，必须为 http(s) URL",
          "pattern": "^https?://.*\\S$"
        },
        "issues": {
          "type": "string",
          "description": "问题反馈地址，必须为 http(s) URL",
          "pattern": "^https?://.*\\S$"
        }
      },
      "additionalProperties": false
    },
    "host_application": {
      "$ref": "#/definitions/version_range",
      "description": "宿主应用（MaiBot）版本要求，min_version 和 max_version 均为闭区间"
    },
    "sdk": {
      "$ref": "#/definitions/version_range",
      "description": "maibot-plugin-sdk 版本要求，min_version 和 max_version 均为闭区间"
    },
    "dependencies": {
      "type": "array",
      "description": "依赖声明列表。插件依赖与 Python 包依赖都在此字段中声明，并通过 type 区分",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "type",
              "id",
              "version_spec"
            ],
            "properties": {
              "type": {
                "const": "plugin",
                "description": "插件依赖"
              },
              "id": {
                "type": "string",
                "description": "依赖插件 ID",
                "pattern": "^[A-Za-z0-9_]+(?:[.-][A-Za-z0-9_]+)+$"
              },
              "version_spec": {
                "type": "string",
                "description": "插件依赖版本约束表达式，由 packaging.specifiers.SpecifierSet 校验",
                "minLength": 1,
                "pattern": "\\S"
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "type",
              "name",
              "version_spec"
            ],
            "properties": {
              "type": {
                "const": "python_package",
                "description": "Python 包依赖"
              },
              "name": {
                "type": "string",
                "description": "Python 包名",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
              },
              "version_spec": {
                "type": "string",
                "description": "Python 包版本约束表达式，由 packaging.requirements.Requirement 校验",
                "minLength": 1,
                "pattern": "\\S"
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "default": [ ]
    },
    "capabilities": {
      "type": "array",
      "description": "插件使用的能力声明列表。使用 ctx.xxx.yyy() 时需要声明对应能力名",
      "items": {
        "type": "string",
        "oneOf": [
          {
            "const": "api.call",
            "description": "调用其他插件暴露的 API 接口"
          },
          {
            "const": "api.get",
            "description": "获取指定 API 的详细信息"
          },
          {
            "const": "api.list",
            "description": "列出当前插件可见的插件 API"
          },
          {
            "const": "api.replace_dynamic",
            "description": "替换当前插件暴露的动态 API 集合"
          },
          {
            "const": "chat.get_all_streams",
            "description": "获取所有聊天流列表"
          },
          {
            "const": "chat.get_group_streams",
            "description": "获取所有群聊聊天流列表"
          },
          {
            "const": "chat.get_private_streams",
            "description": "获取所有私聊聊天流列表"
          },
          {
            "const": "chat.get_stream_by_group_id",
            "description": "根据群号获取聊天流信息"
          },
          {
            "const": "chat.get_stream_by_user_id",
            "description": "根据用户 ID 获取私聊聊天流信息"
          },
          {
            "const": "chat.open_session",
            "description": "按平台目标打开或创建聊天流"
          },
          {
            "const": "component.disable",
            "description": "禁用组件"
          },
          {
            "const": "component.enable",
            "description": "启用组件"
          },
          {
            "const": "component.get_all_plugins",
            "description": "获取所有已注册插件信息"
          },
          {
            "const": "component.get_plugin_config_schema",
            "description": "获取指定插件的配置 Schema"
          },
          {
            "const": "component.get_plugin_info",
            "description": "获取指定插件信息"
          },
          {
            "const": "component.list_loaded_plugins",
            "description": "列出所有已加载插件"
          },
          {
            "const": "component.list_registered_plugins",
            "description": "列出所有已注册插件"
          },
          {
            "const": "component.load_plugin",
            "description": "加载指定插件"
          },
          {
            "const": "component.reload_plugin",
            "description": "重新加载指定插件"
          },
          {
            "const": "component.unload_plugin",
            "description": "卸载指定插件"
          },
          {
            "const": "component.update_plugin_config",
            "description": "更新指定插件配置"
          },
          {
            "const": "config.get",
            "description": "获取单个配置项的值"
          },
          {
            "const": "config.get_all",
            "description": "获取所有配置项"
          },
          {
            "const": "config.get_plugin",
            "description": "获取指定插件的配置"
          },
          {
            "const": "database.count",
            "description": "统计数据库中符合条件的记录数量"
          },
          {
            "const": "database.delete",
            "description": "从数据库中删除记录"
          },
          {
            "const": "database.get",
            "description": "从数据库中获取单条记录"
          },
          {
            "const": "database.query",
            "description": "查询数据库中的记录"
          },
          {
            "const": "database.save",
            "description": "保存记录到数据库"
          },
          {
            "const": "emoji.delete",
            "description": "删除表情包"
          },
          {
            "const": "emoji.get_all",
            "description": "获取所有可用表情列表"
          },
          {
            "const": "emoji.get_by_description",
            "description": "根据描述搜索表情"
          },
          {
            "const": "emoji.get_count",
            "description": "获取表情总数"
          },
          {
            "const": "emoji.get_emotions",
            "description": "获取情绪分类的表情列表"
          },
          {
            "const": "emoji.get_info",
            "description": "获取表情统计信息"
          },
          {
            "const": "emoji.get_random",
            "description": "获取随机表情"
          },
          {
            "const": "emoji.register",
            "description": "注册表情包"
          },
          {
            "const": "frequency.get_adjust",
            "description": "获取频率调整值"
          },
          {
            "const": "frequency.get_current_talk_value",
            "description": "获取当前对话频率值"
          },
          {
            "const": "frequency.set_adjust",
            "description": "设置频率调整值"
          },
          {
            "const": "gateway.route_message",
            "description": "通过消息网关注入外部平台消息"
          },
          {
            "const": "gateway.update_state",
            "description": "上报消息网关运行时状态"
          },
          {
            "const": "knowledge.search",
            "description": "搜索知识库内容"
          },
          {
            "const": "llm.embed",
            "description": "将文本转换为向量表示"
          },
          {
            "const": "llm.generate",
            "description": "调用 LLM 生成文本"
          },
          {
            "const": "llm.generate_with_tools",
            "description": "调用支持工具的 LLM 生成"
          },
          {
            "const": "llm.get_available_models",
            "description": "获取所有可用的 LLM 模型列表"
          },
          {
            "const": "llm.transcribe_audio",
            "description": "将音频转换为文字"
          },
          {
            "const": "maisaka.context.append",
            "description": "向 Maisaka 上下文追加图文消息"
          },
          {
            "const": "maisaka.proactive.trigger",
            "description": "触发 Maisaka 主动任务"
          },
          {
            "const": "message.build_readable",
            "description": "将消息格式化为可读文本"
          },
          {
            "const": "message.count_new",
            "description": "统计指定聊天流的新消息数量"
          },
          {
            "const": "message.get_by_id",
            "description": "根据消息 ID 获取消息内容"
          },
          {
            "const": "message.get_by_time",
            "description": "根据时间范围获取消息列表"
          },
          {
            "const": "message.get_by_time_in_chat",
            "description": "在指定聊天流中根据时间范围获取消息"
          },
          {
            "const": "message.get_recent",
            "description": "获取最近的消息列表"
          },
          {
            "const": "person.get_id",
            "description": "获取 Person ID"
          },
          {
            "const": "person.get_id_by_name",
            "description": "根据用户名获取 Person ID"
          },
          {
            "const": "person.get_value",
            "description": "获取用户属性值"
          },
          {
            "const": "render.html2png",
            "description": "将 HTML 内容渲染为 PNG 图片"
          },
          {
            "const": "send.command",
            "description": "发送命令消息到指定聊天流"
          },
          {
            "const": "send.custom",
            "description": "发送自定义格式消息到指定聊天流"
          },
          {
            "const": "send.emoji",
            "description": "发送表情消息到指定聊天流"
          },
          {
            "const": "send.forward",
            "description": "发送合并转发消息到指定聊天流"
          },
          {
            "const": "send.hybrid",
            "description": "发送混合类型消息到指定聊天流"
          },
          {
            "const": "send.image",
            "description": "发送图片消息到指定聊天流"
          },
          {
            "const": "send.text",
            "description": "发送文本消息到指定聊天流"
          },
          {
            "const": "statistics.local.message_trend",
            "description": "获取本机聊天流消息量趋势"
          },
          {
            "const": "statistics.local.model_trend",
            "description": "获取本机模型调用趋势"
          },
          {
            "const": "statistics.local.models",
            "description": "获取本机模型维度汇总统计"
          },
          {
            "const": "statistics.local.online_time_trend",
            "description": "获取本机在线时长趋势"
          },
          {
            "const": "statistics.local.token_distribution",
            "description": "获取本机 token 使用分布"
          },
          {
            "const": "statistics.local.token_trend",
            "description": "获取本机 token 使用趋势"
          },
          {
            "const": "statistics.local.tool_trend",
            "description": "获取本机工具调用趋势"
          },
          {
            "const": "tool.get_definitions",
            "description": "获取所有已注册工具定义"
          }
        ]
      }
    },
    "i18n": {
      "type": "object",
      "description": "国际化配置",
      "required": [
        "default_locale"
      ],
      "properties": {
        "default_locale": {
          "type": "string",
          "description": "默认语言，若 supported_locales 非空则必须包含在其中",
          "minLength": 1,
          "pattern": "\\S"
        },
        "locales_path": {
          "type": "string",
          "description": "语言文件目录路径，相对于插件目录",
          "minLength": 1,
          "pattern": "\\S",
          "default": "_locales"
        },
        "supported_locales": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "description": "支持的语言代码列表，运行时会去重，但不会拒绝重复项",
          "default": [ ]
        }
      },
      "additionalProperties": false
    },
    "id": {
      "type": "string",
      "description": "插件唯一标识符，应使用字母、数字、下划线，并以点号或横线分隔，例如 github.author.plugin",
      "pattern": "^[A-Za-z0-9_]+(?:[.-][A-Za-z0-9_]+)+$",
      "minLength": 1
    },
    "llm_providers": {
      "type": "array",
      "description": "LLM Provider 静态声明列表，必须与 @LLMProvider 装饰器收集结果完全一致",
      "items": {
        "type": "object",
        "required": [
          "client_type"
        ],
        "properties": {
          "client_type": {
            "type": "string",
            "description": "Provider 客户端类型标识",
            "minLength": 1,
            "pattern": "\\S"
          },
          "name": {
            "type": "string",
            "description": "Provider 展示名称",
            "default": ""
          },
          "description": {
            "type": "string",
            "description": "Provider 描述",
            "default": ""
          },
          "version": {
            "type": "string",
            "description": "Provider 实现版本",
            "default": "1.0.0"
          }
        },
        "additionalProperties": false
      },
      "default": [ ]
    },
    "plugin_type": {
      "type": "string",
      "description": "插件类型，用于 WebUI 展示和分类；未声明时运行时默认为 extension",
      "oneOf": [
        {
          "const": "adapter",
          "description": "适配器"
        },
        {
          "const": "chat",
          "description": "聊天"
        },
        {
          "const": "creative",
          "description": "创作"
        },
        {
          "const": "provider",
          "description": "服务提供方"
        },
        {
          "const": "management",
          "description": "管理"
        },
        {
          "const": "search",
          "description": "检索搜索"
        },
        {
          "const": "knowledge",
          "description": "知识"
        },
        {
          "const": "media",
          "description": "媒体"
        },
        {
          "const": "game",
          "description": "游戏娱乐"
        },
        {
          "const": "security",
          "description": "安全防护"
        },
        {
          "const": "automation",
          "description": "自动化"
        },
        {
          "const": "extension",
          "description": "通用扩展"
        },
        {
          "const": "other",
          "description": "其他"
        }
      ],
      "default": "extension"
    },
    "display": {
      "type": "object",
      "description": "插件展示元信息",
      "properties": {
        "icon": {
          "type": "object",
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "type": "string",
              "description": "图标类型",
              "enum": [
                "lucide",
                "emoji",
                "local"
              ]
            },
            "value": {
              "type": "string",
              "description": "图标值。lucide 为图标名，emoji 为字符，local 为插件目录内相对路径",
              "minLength": 1,
              "pattern": "\\S"
            },
            "fallback": {
              "type": "string",
              "description": "图标加载失败时使用的 lucide 图标名",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
            },
            "background": {
              "type": "string",
              "description": "图标背景色",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "lucide"
                  }
                },
                "required": [
                  "type"
                ]
              },
              "then": {
                "properties": {
                  "value": {
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "local"
                  }
                },
                "required": [
                  "type"
                ]
              },
              "then": {
                "properties": {
                  "value": {
                    "pattern": "^(?!/)(?!\\\\)(?![A-Za-z]:[\\\\/])(?!.*\\u0000)(?!.*(^|[/\\\\])\\.\\.([/\\\\]|$)).+\\.([jJ][pP][eE]?[gG]|[pP][nN][gG]|[sS][vV][gG]|[wW][eE][bB][pP])$"
                  }
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "changelog": {
      "type": "string",
      "description": "更新日志地址或插件目录内 Markdown 相对路径",
      "minLength": 1,
      "pattern": "\\S",
      "anyOf": [
        {
          "pattern": "^https?://.*\\S$",
          "description": "http(s) 更新日志地址"
        },
        {
          "pattern": "^(?!/)(?!\\\\)(?![A-Za-z]:[\\\\/])(?!.*\\u0000)(?!.*(^|[/\\\\])\\.\\.([/\\\\]|$)).+\\.[mM][dD]$",
          "description": "插件目录内 Markdown 相对路径"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "version_range": {
      "type": "object",
      "required": [
        "min_version",
        "max_version"
      ],
      "properties": {
        "min_version": {
          "type": "string",
          "description": "最小版本，闭区间",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "max_version": {
          "type": "string",
          "description": "最大版本，闭区间",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    }
  }
}
